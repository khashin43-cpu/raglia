# Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
ENABLE_OLLAMA_API='false'
OLLAMA_BASE_URL='http://localhost:11434'

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# Product identity
WEBUI_NAME='ЛИА'
ENABLE_VERSION_UPDATE_CHECK='false'
# Required when authentication is enabled. Use a unique long random value.
WEBUI_SECRET_KEY='replace-with-a-long-random-secret'

# Optional RAGFlow 0.24 integration. Use only the server origin, without
# /api/v1, for example http://192.168.0.10:8080.
RAGFLOW_URL=''
RAGFLOW_API_KEY=''
# Optional diagnostic endpoint. Original files are downloaded through the
# authenticated RAGFlow Document API, so MinIO credentials are not required.
RAGFLOW_MINIO_URL=''

# Aria system agent. Accepts an OpenAI-compatible /v1 API root or the full
# /v1/chat/completions endpoint.
LIA_ARIA_ENABLED='false'
LIA_ARIA_API_BASE_URL=''
LIA_ARIA_API_KEY=''
LIA_ARIA_MODEL='/model'

# System document assistant powered by Aria and the local OfficeCLI binary.
# Install the binary with ./backend/install_officecli.sh.
LIA_OFFICE_ENABLED='false'
LIA_OFFICECLI_BINARY='./backend/bin/officecli'
LIA_OFFICECLI_WORK_DIR='./backend/data/officecli'
LIA_OFFICECLI_TIMEOUT='120'

# SIP / LND system agent. Set an OpenAI-compatible /v1 API root, for example
# http://192.168.0.10:7777/v1, or the full /v1/chat/completions URL.
LIA_LND_ENABLED='false'
LIA_LND_API_BASE_URL=''
LIA_LND_API_KEY=''

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# Set to false to keep memory tools enabled without adding memory context to the system context.
ENABLE_MEMORY_SYSTEM_CONTEXT=true

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# Valkey Vector Store (requires VECTOR_DB=valkey)
# VALKEY_URL='valkey://localhost:6379'
# VALKEY_COLLECTION_PREFIX='open_webui'
# VALKEY_INDEX_TYPE='HNSW'
# VALKEY_DISTANCE_METRIC='COSINE'
# VALKEY_HNSW_M='16'
# VALKEY_HNSW_EF_CONSTRUCTION='200'
# VALKEY_HNSW_EF_RUNTIME='10'
